# ============================================================
#  StockViet AI — Cấu hình môi trường (.env)
#  Sao chép file này thành .env và điền giá trị thật.
#  KHÔNG commit file .env (đã được .gitignore bỏ qua).
# ============================================================

# --- LLM (Google Gemini qua LiteLLM) ---
# Lấy API key tại: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
LITELLM_MODEL=gemini/gemini-2.5-flash

# --- Thị trường & ngôn ngữ (mặc định Việt Nam) ---
MARKET_REVIEW_REGION=vn
REPORT_LANGUAGE=vi

# --- Danh sách cổ phiếu theo dõi (mã .VN, phân tách bằng dấu phẩy) ---
STOCK_LIST=VCB.VN,VIC.VN,HPG.VN,VNM.VN,FPT.VN,MWG.VN,MSN.VN,TCB.VN,VHM.VN,SSI.VN

# --- Cơ sở dữ liệu (SQLite, tự tạo nếu chưa có) ---
DATABASE_PATH=./data/stock_analysis.db

# --- Máy chủ web ---
# Cổng/host truyền qua tham số dòng lệnh:
#   python main.py --serve-only --host 127.0.0.1 --port 8000

# --- Thông báo (tuỳ chọn — Telegram/Email/Discord/Slack/ntfy/Gotify/Pushover) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
