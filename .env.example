# ============================================================
#  La Bàn Đầu Tư — Cấu hình môi trường (.env)
#  Sao chép file này thành .env và điền giá trị thật.
#  KHÔNG commit file .env (đã được .gitignore bỏ qua).
# ============================================================

# --- AI (qua LiteLLM — không khoá cứng vào một hãng) ---
# Mặc định Google Gemini (lấy key miễn phí: https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your_gemini_api_key_here
LITELLM_MODEL=gemini/gemini-2.5-flash
#
# Muốn dùng hãng khác? Đổi LITELLM_MODEL + điền khoá tương ứng (bỏ dấu # ở dòng cần dùng):
#   OpenAI:    LITELLM_MODEL=openai/gpt-4o-mini       + OPENAI_API_KEY=...
#   Anthropic: LITELLM_MODEL=anthropic/claude-3-5-haiku-latest + ANTHROPIC_API_KEY=...
#   Endpoint tương thích OpenAI (self-host/OpenRouter): thêm OPENAI_BASE_URL=...
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# OPENAI_BASE_URL=

# --- Thị trường & ngôn ngữ (mặc định Việt Nam) ---
MARKET_REVIEW_REGION=vn
REPORT_LANGUAGE=vi

# --- Danh sách cổ phiếu theo dõi (mã .VN, phân tách bằng dấu phẩy) ---
STOCK_LIST=VCB.VN,VIC.VN,HPG.VN,VNM.VN,FPT.VN,MWG.VN,MSN.VN,TCB.VN,VHM.VN,SSI.VN

# --- Cơ sở dữ liệu (SQLite, tự tạo nếu chưa có) ---
DATABASE_PATH=./data/stock_analysis.db

# --- Máy chủ web ---
# Cổng/host truyền qua tham số dòng lệnh:
#   python main.py --serve-only --host 127.0.0.1 --port 8000

# --- BẢO MẬT (BẮT BUỘC bật khi đưa lên Internet) ---
# Khi TẮT (mặc định, tiện chạy nội bộ): mọi API mở, không cần đăng nhập.
# Khi BẬT: mọi /api/v1/* cần đăng nhập; lần đăng nhập đầu sẽ đặt mật khẩu quản trị.
# ⚠️ Triển khai công khai: ĐẶT ADMIN_AUTH_ENABLED=true.
# ADMIN_AUTH_ENABLED=true
# ADMIN_SESSION_MAX_AGE_HOURS=24
# Đặt true CHỈ khi chạy sau một reverse proxy tin cậy (để đọc X-Forwarded-For):
# TRUST_X_FORWARDED_FOR=false
# Danh sách origin được phép gọi API (phân tách bằng dấu phẩy). Để trống là an toàn nhất.
# CORS_ORIGINS=https://your-domain.example
# KHÔNG bật trên Internet — chỉ cho mạng nội bộ tin cậy:
# CORS_ALLOW_ALL=false

# --- Thông báo (tuỳ chọn — Telegram/Email/Discord/Slack/ntfy/Gotify/Pushover) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Tìm kiếm tin tức (tuỳ chọn — SearXNG) ---
# Địa chỉ SearXNG tự dựng (nhiều địa chỉ phân tách bằng dấu phẩy).
# Trên GitHub Actions: cấu hình qua Variables (ưu tiên), Secrets (dự phòng) — địa chỉ
# công khai nên dùng Variables. Để trống → tự lấy instance công khai từ searx.space.
SEARXNG_BASE_URLS=
SEARXNG_PUBLIC_INSTANCES_ENABLED=true
